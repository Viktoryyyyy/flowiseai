{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"github_execution_request.schema.json","title":"GitHub Execution Request Contract","type":"object","additionalProperties":false,"required":["contract_version","request_id","phase_run_id","requested_operation_type","repository_full_name","base_ref","base_sha","branch_name","approved_file_scope","pr_metadata","ci_expectation","result_evidence","safety_boundaries","secrets","private_endpoints","created_at"],"properties":{"contract_version":{"type":"string","pattern":"^\\d+\\.\\d+\\.\\d+$"},"request_id":{"type":"string","minLength":1},"phase_run_id":{"type":"string","minLength":1},"requested_operation_type":{"enum":["create_branch","commit_approved_scope","open_pull_request","verify_ci","update_pull_request_metadata"]},"repository_full_name":{"type":"string","pattern":"^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},"base_ref":{"type":"string","minLength":1},"base_sha":{"type":"string","pattern":"^[0-9a-f]{40}$"},"branch_name":{"type":"string","minLength":1},"approved_file_scope":{"type":"array","items":{"type":"string","minLength":1},"minItems":1},"pr_metadata":{"type":"object","additionalProperties":false,"required":["title","body_required","base_branch","draft"],"properties":{"title":{"type":"string","minLength":1},"body_required":{"type":"boolean"},"base_branch":{"type":"string","minLength":1},"draft":{"type":"boolean"}}},"ci_expectation":{"type":"object","additionalProperties":false,"required":["ci_required","workflow_name","evidence_must_match_head_sha"],"properties":{"ci_required":{"type":"boolean"},"workflow_name":{"type":["string","null"],"minLength":1},"evidence_must_match_head_sha":{"const":true}}},"result_evidence":{"type":"object","additionalProperties":false,"required":["commit_sha","pr_number","workflow_run_id","conclusion"],"properties":{"commit_sha":{"type":["string","null"],"pattern":"^[0-9a-f]{40}$"},"pr_number":{"type":["integer","null"],"minimum":1},"workflow_run_id":{"type":["integer","null"],"minimum":1},"conclusion":{"enum":["not_started","pending","success","failure","cancelled","skipped","not_required"]}}},"safety_boundaries":{"type":"object","additionalProperties":false,"required":["direct_main_write_allowed","server_apply_allowed","deployment_allowed","runtime_smoke_allowed","secrets_allowed","private_endpoints_allowed"],"properties":{"direct_main_write_allowed":{"const":false},"server_apply_allowed":{"const":false},"deployment_allowed":{"const":false},"runtime_smoke_allowed":{"const":false},"secrets_allowed":{"const":false},"private_endpoints_allowed":{"const":false}}},"secrets":{"type":"array","maxItems":0},"private_endpoints":{"type":"array","maxItems":0},"created_at":{"type":"string","minLength":20,"description":"UTC timestamp encoded as an RFC3339 string."},"metadata":{"type":"object","additionalProperties":true}}}
