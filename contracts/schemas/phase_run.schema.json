{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"phase_run.schema.json","title":"PhaseRun Contract","type":"object","additionalProperties":false,"required":["contract_version","phase_run_id","project","lane","execution_mode","source_repository","base_ref","base_sha","branch_refs","pr_refs","authority_boundary","lifecycle_state","status","timestamps","blockers"],"properties":{"contract_version":{"type":"string","pattern":"^\\d+\\.\\d+\\.\\d+$"},"phase_run_id":{"type":"string","minLength":1},"project":{"const":"MOEX Bot"},"lane":{"type":"string","minLength":1},"execution_mode":{"enum":["browser_chatgpt_github_direct","route_b_n8n_universal_role_runner"]},"source_repository":{"type":"object","additionalProperties":false,"required":["repository_full_name","default_branch"],"properties":{"repository_full_name":{"type":"string","pattern":"^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},"default_branch":{"type":"string","minLength":1}}},"base_ref":{"type":"string","minLength":1},"base_sha":{"type":"string","pattern":"^[0-9a-f]{40}$"},"branch_refs":{"type":"object","additionalProperties":false,"required":["approved_branch_name","active_branch_name"],"properties":{"approved_branch_name":{"type":"string","minLength":1},"active_branch_name":{"type":["string","null"],"minLength":1}}},"pr_refs":{"type":"object","additionalProperties":false,"required":["active_pr_number","active_pr_head_sha"],"properties":{"active_pr_number":{"type":["integer","null"],"minimum":1},"active_pr_head_sha":{"type":["string","null"],"pattern":"^[0-9a-f]{40}$"}}},"authority_boundary":{"type":"object","additionalProperties":false,"required":["merge_authority","direct_main_write_allowed","server_apply_authority","runtime_allowed","deployment_allowed","runtime_smoke_allowed","secrets_allowed"],"properties":{"merge_authority":{"const":"PM_L2_ONLY"},"direct_main_write_allowed":{"const":false},"server_apply_authority":{"enum":["blocked_until_explicit_future_phase","PM_L2_ONLY_OR_EXPLICIT_PM_L2_TASK","NONE