{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/audit-event.schema.json",
  "title": "FlowiseAI PM Audit Event Contract",
  "type": "object",
  "required": [
    "event_id",
    "schema_version",
    "occurred_at",
    "project",
    "task_id",
    "lane",
    "execution_mode",
    "actor_role",
    "event_type",
    "subject_ref",
    "evidence_ref",
    "outcome",
    "redaction_state"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "lane": {
      "type": "string",
      "enum": [
        "route_b_n8n",
        "ema_3_19_ai",
        "integration"
      ]
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "browser_chatgpt_github_direct",
        "route_b_n8n_universal_role_runner"
      ]
    },
    "actor_role": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "handoff_created",
        "role_started",
        "spec_completed",
        "implementation_committed",
        "pr_opened",
        "ci_started",
        "ci_completed",
        "validation_completed",
        "blocker_reported",
        "merge_approved",
        "merge_completed",
        "server_apply_requested",
        "server_apply_completed"
      ]
    },
    "subject_ref": {
      "type": "object",
      "additionalProperties": true
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": true
    },
    "outcome": {
      "type": "string",
      "minLength": 1
    },
    "redaction_state": {
      "type": "string",
      "enum": [
        "no_secret_payload",
        "redacted"
      ]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
