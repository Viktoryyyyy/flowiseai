{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/task.schema.json",
  "title": "FlowiseAI PM Task Contract",
  "type": "object",
  "required": [
    "contract_version",
    "task_id",
    "project",
    "lane",
    "execution_mode",
    "repository_full_name",
    "base_ref",
    "base_sha",
    "branch_name",
    "assigned_role",
    "current_goal",
    "approved_file_scope",
    "forbidden_file_scope",
    "authority_boundary",
    "acceptance_criteria",
    "stop_conditions",
    "created_at"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "lane": {
      "type": "string",
      "enum": [
        "route_b_n8n",
        "ema_3_19_ai",
        "integration"
      ]
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "browser_chatgpt_github_direct",
        "route_b_n8n_universal_role_runner"
      ]
    },
    "repository_full_name": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "base_ref": {
      "type": "string",
      "minLength": 1
    },
    "base_sha": {
      "type": "string",
      "pattern": "^([a-f0-9]{40}|not_checked|not_applicable)$"
    },
    "branch_name": {
      "type": "string",
      "minLength": 1
    },
    "assigned_role": {
      "type": "string",
      "minLength": 1
    },
    "current_goal": {
      "type": "string",
      "minLength": 1
    },
    "approved_file_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "forbidden_file_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "authority_boundary": {
      "type": "object",
      "required": [
        "merge_authority",
        "direct_main_write_allowed",
        "server_apply_authority",
        "runtime_allowed"
      ],
      "properties": {
        "merge_authority": {
          "type": "string",
          "minLength": 1
        },
        "direct_main_write_allowed": {
          "type": "boolean",
          "const": false
        },
        "server_apply_authority": {
          "type": "string",
          "minLength": 1
        },
        "runtime_allowed": {
          "type": "string",
          "enum": [
            "yes",
            "no"
          ]
        }
      },
      "additionalProperties": true
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "properties": {
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
