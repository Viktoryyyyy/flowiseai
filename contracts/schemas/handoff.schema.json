{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/handoff.schema.json",
  "title": "FlowiseAI PM Handoff Contract",
  "type": "object",
  "required": [
    "handoff_id",
    "handoff_version",
    "project",
    "from_role",
    "to_role",
    "created_at",
    "root_task",
    "task_id",
    "lane",
    "execution_mode",
    "current_goal",
    "verified_current_state",
    "relevant_repository_state",
    "decisions_already_made",
    "approved_scope",
    "forbidden_scope",
    "shared_file_lock",
    "blockers",
    "unknowns",
    "acceptance_criteria",
    "exact_task_for_receiver",
    "required_first_checks",
    "stop_conditions",
    "required_return_format",
    "authority_boundary",
    "previous_role_report_summary",
    "expiry_conditions"
  ],
  "properties": {
    "handoff_id": {
      "type": "string",
      "minLength": 1
    },
    "handoff_version": {
      "type": "integer",
      "minimum": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "from_role": {
      "type": "string",
      "minLength": 1
    },
    "to_role": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "root_task": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "lane": {
      "type": "string",
      "enum": [
        "route_b_n8n",
        "ema_3_19_ai",
        "integration"
      ]
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "browser_chatgpt_github_direct",
        "route_b_n8n_universal_role_runner"
      ]
    },
    "current_goal": {
      "type": "string",
      "minLength": 1
    },
    "verified_current_state": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "fact",
          "proof"
        ],
        "properties": {
          "fact": {
            "type": "string",
            "minLength": 1
          },
          "proof": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "relevant_repository_state": {
      "type": "object",
      "additionalProperties": true
    },
    "decisions_already_made": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "approved_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "forbidden_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "shared_file_lock": {
      "type": "object",
      "additionalProperties": true
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "exact_task_for_receiver": {
      "type": "string",
      "minLength": 1
    },
    "required_first_checks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "required_return_format": {
      "type": [
        "object",
        "string"
      ],
      "minLength": 1
    },
    "authority_boundary": {
      "type": "object",
      "required": [
        "merge_authority",
        "direct_main_write_allowed",
        "server_apply_authority",
        "runtime_allowed"
      ],
      "properties": {
        "merge_authority": {
          "type": "string",
          "minLength": 1
        },
        "direct_main_write_allowed": {
          "type": "boolean"
        },
        "server_apply_authority": {
          "type": "string",
          "minLength": 1
        },
        "runtime_allowed": {
          "type": "string",
          "enum": [
            "yes",
            "no"
          ]
        }
      },
      "additionalProperties": true
    },
    "previous_role_report_summary": {
      "type": "object",
      "required": [
        "done",
        "not_done",
        "blockers"
      ],
      "properties": {
        "done": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "not_done": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "expiry_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "metadata": {
      "type": "object",
      "properties": {
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
