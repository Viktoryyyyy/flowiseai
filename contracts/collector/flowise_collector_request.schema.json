{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/collector/flowise_collector_request.schema.json",
  "title": "Flowise Collector Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "correlation_id"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "graph_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "runtime_graph_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "base_url": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "form": {
      "type": "object",
      "additionalProperties": true
    },
    "override_config": {
      "type": "object",
      "additionalProperties": true
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "uploads": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "timeout_seconds": {
      "type": "number",
      "minimum": 1,
      "maximum": 120,
      "default": 30
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "anyOf": [
        {
          "required": [
            "graph_id"
          ]
        },
        {
          "required": [
            "runtime_graph_id"
          ]
        }
      ]
    },
    {
      "anyOf": [
        {
          "required": [
            "question"
          ]
        },
        {
          "required": [
            "form"
          ]
        }
      ]
    }
  ]
}
